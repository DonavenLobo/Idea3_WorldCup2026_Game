{
  "name": "gogaffa",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.19.0 <23",
    "pnpm": ">=9.15.0"
  },
  "scripts": {
    "assets:card-template": "node scripts/create-transparent-card-template.cjs",
    "assets:shield-cutout": "node scripts/transparentize-black-cutout.cjs",
    "preview:card": "node scripts/preview-card.cjs",
    "dev": "turbo dev",
    "dev:mobile": "pnpm --filter mobile start",
    "dev:mobile:client": "pnpm --filter mobile start:dev-client",
    "build": "turbo build",
    "mobile:eas:build:dev": "pnpm --filter mobile eas:build:dev",
    "mobile:eas:build:dev:ios": "pnpm --filter mobile eas:build:dev:ios",
    "mobile:eas:build:dev:android": "pnpm --filter mobile eas:build:dev:android",
    "mobile:eas:build:preview": "pnpm --filter mobile eas:build:preview",
    "mobile:eas:build:production": "pnpm --filter mobile eas:build:production",
    "mobile:eas:build:ios": "pnpm --filter mobile eas:build:ios",
    "mobile:eas:build:android": "pnpm --filter mobile eas:build:android",
    "mobile:eas:submit:ios": "pnpm --filter mobile eas:submit:ios",
    "mobile:eas:submit:android": "pnpm --filter mobile eas:submit:android",
    "build:visual:web": "pnpm --filter mobile exec expo export --platform web --output-dir ../../.playwright-expo-web",
    "lint": "turbo lint",
    "serve:visual:web": "pnpm build:visual:web && node scripts/serve-spa.cjs .playwright-expo-web 19006",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:unit": "vitest run --passWithNoTests",
    "test:visual": "playwright test",
    "test:visual:headed": "playwright test --headed",
    "test:visual:ui": "playwright test --ui",
    "build:schedule": "node scripts/build-schedule.mjs",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:reset": "supabase db reset",
    "supabase:types": "supabase gen types typescript --local > packages/types/src/database.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "pngjs": "^7.0.0",
    "sharp": "^0.34.5",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  }
}
