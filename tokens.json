{
  "$schema": "https://gogaffa.com/brand/tokens.schema.json",
  "brand": "GoGaffa",
  "version": "1.0.0",

  "colour": {
    "cream": {
      "hex": "#f5f0e8",
      "rgb": "rgb(245, 240, 232)",
      "hsl": "hsl(37, 39%, 94%)",
      "role": "background",
      "cssVar": "--color-cream"
    },
    "ink": {
      "hex": "#1a1a2e",
      "rgb": "rgb(26, 26, 46)",
      "hsl": "hsl(240, 28%, 14%)",
      "role": "text-borders",
      "cssVar": "--color-ink"
    },
    "red": {
      "hex": "#e63946",
      "rgb": "rgb(230, 57, 70)",
      "hsl": "hsl(355, 78%, 56%)",
      "role": "energy-cta",
      "cssVar": "--color-red"
    },
    "blue": {
      "hex": "#1d3557",
      "rgb": "rgb(29, 53, 87)",
      "hsl": "hsl(215, 50%, 23%)",
      "role": "identity-trust",
      "cssVar": "--color-blue"
    },
    "purple": {
      "hex": "#6b4c9a",
      "rgb": "rgb(107, 76, 154)",
      "hsl": "hsl(264, 34%, 45%)",
      "role": "tournament-prestige",
      "cssVar": "--color-purple"
    },
    "success": {
      "hex": "#2f7a4d",
      "rgb": "rgb(47, 122, 77)",
      "hsl": "hsl(144, 44%, 33%)",
      "role": "confirmation",
      "cssVar": "--color-success"
    }
  },

  "opacity": {
    "ink-100": { "value": 1.0, "usage": "Headlines, primary text, borders" },
    "ink-85": { "value": 0.85, "usage": "Card body text (desktop)" },
    "ink-80": { "value": 0.80, "usage": "Card body text (mobile), secondary descriptions" },
    "ink-70": { "value": 0.70, "usage": "Footer navigation links, kicker text" },
    "ink-60": { "value": 0.60, "usage": "Footnotes, dot counter text" },
    "ink-55": { "value": 0.55, "usage": "Date labels" },
    "ink-35": { "value": 0.35, "usage": "Input placeholder text" },
    "ink-30": { "value": 0.30, "usage": "Decorative bullet separators" },
    "ink-15": { "value": 0.15, "usage": "Content panel borders" },
    "cream-80": { "value": 0.80, "usage": "Arrow button background" },
    "cream-75": { "value": 0.75, "usage": "Content panel background" },
    "cream-70": { "value": 0.70, "usage": "Input field background" },
    "red-50": { "value": 0.50, "usage": "Input focus ring" }
  },

  "typography": {
    "families": {
      "caveat": {
        "family": "Caveat",
        "fallback": "\"Comic Sans MS\", cursive",
        "stack": "Caveat, \"Comic Sans MS\", cursive",
        "cssVar": "--font-caveat",
        "weights": [400, 500, 600, 700],
        "role": "personality"
      },
      "inter": {
        "family": "Inter",
        "fallback": "system-ui, -apple-system, sans-serif",
        "stack": "Inter, system-ui, -apple-system, sans-serif",
        "cssVar": "--font-inter",
        "weights": [400, 600, 700],
        "role": "system-ui"
      }
    },
    "scale": {
      "page-title-large": {
        "font": "caveat",
        "sizePx": [60, 72, 96],
        "sizeClass": "text-6xl sm:text-7xl lg:text-8xl",
        "weight": 700,
        "lineHeight": 0.92
      },
      "page-title": {
        "font": "caveat",
        "sizePx": [60, 72],
        "sizeClass": "text-6xl sm:text-7xl",
        "weight": 700,
        "lineHeight": "none"
      },
      "card-title": {
        "font": "caveat",
        "sizePx": [48, 60, 72],
        "sizeClass": "text-5xl sm:text-6xl lg:text-7xl",
        "weight": 700,
        "lineHeight": 0.92
      },
      "section-heading": {
        "font": "caveat",
        "sizePx": [30],
        "sizeClass": "text-3xl",
        "weight": 700,
        "lineHeight": "default"
      },
      "body-card-desktop": {
        "font": "caveat",
        "sizePx": [24, 30],
        "sizeClass": "text-2xl sm:text-3xl",
        "weight": 400,
        "lineHeight": "snug"
      },
      "body-card-mobile": {
        "font": "caveat",
        "sizePx": [24],
        "sizeClass": "text-2xl",
        "weight": 400,
        "lineHeight": "snug"
      },
      "body-support": {
        "font": "caveat",
        "sizePx": [30],
        "sizeClass": "text-3xl",
        "weight": 400,
        "lineHeight": "tight"
      },
      "button": {
        "font": "caveat",
        "sizePx": [30],
        "sizeClass": "text-3xl",
        "weight": 700,
        "lineHeight": "default"
      },
      "input": {
        "font": "caveat",
        "sizePx": [24],
        "sizeClass": "text-2xl",
        "weight": 400,
        "lineHeight": "default"
      },
      "success": {
        "font": "caveat",
        "sizePx": [24, 30],
        "sizeClass": "text-2xl sm:text-3xl",
        "weight": 600,
        "lineHeight": "default"
      },
      "error": {
        "font": "caveat",
        "sizePx": [18, 20],
        "sizeClass": "text-lg sm:text-xl",
        "weight": 400,
        "lineHeight": "default"
      },
      "footer-nav": {
        "font": "caveat",
        "sizePx": [18],
        "sizeClass": "text-lg",
        "weight": 400,
        "lineHeight": "default"
      },
      "footnote": {
        "font": "caveat",
        "sizePx": [16],
        "sizeClass": "text-base",
        "weight": 400,
        "lineHeight": "default"
      },
      "body-content": {
        "font": "inter",
        "sizePx": [16],
        "sizeClass": "text-base",
        "weight": 400,
        "lineHeight": 1.75
      },
      "date-label": {
        "font": "inter",
        "sizePx": [14],
        "sizeClass": "text-sm",
        "weight": 400,
        "lineHeight": "default"
      },
      "eyebrow": {
        "font": "inter",
        "sizePx": [12],
        "sizeClass": "text-xs",
        "weight": 700,
        "lineHeight": "default",
        "textTransform": "uppercase",
        "letterSpacing": "0.28em"
      }
    }
  },

  "spacing": {
    "borderRadius": {
      "button-cta": "10px",
      "button-cta-large": "14px",
      "input": "10px",
      "content-panel": "28px",
      "arrow-button": "9999px",
      "card-swatch": "12px",
      "tactic-zone": "7px"
    },
    "borderWidth": {
      "default": "2px"
    },
    "shadow": {
      "button-cta": {
        "value": "3px 3px 0 0 var(--color-ink)",
        "offsetX": 3,
        "offsetY": 3,
        "blur": 0,
        "spread": 0,
        "colour": "#1a1a2e"
      },
      "button-cta-large": {
        "value": "4px 4px 0 0 var(--color-ink)",
        "offsetX": 4,
        "offsetY": 4,
        "blur": 0,
        "spread": 0,
        "colour": "#1a1a2e"
      },
      "content-panel": {
        "value": "0 16px 40px -24px rgba(26, 26, 46, 0.45)",
        "offsetX": 0,
        "offsetY": 16,
        "blur": 40,
        "spread": -24,
        "colour": "rgba(26, 26, 46, 0.45)"
      },
      "card-image": {
        "value": "drop-shadow(0 16px 28px rgba(26, 26, 46, 0.34))",
        "type": "drop-shadow",
        "offsetX": 0,
        "offsetY": 16,
        "blur": 28,
        "colour": "rgba(26, 26, 46, 0.34)"
      }
    },
    "cardAspectRatio": "682 / 1024",
    "cardMaxWidth": "520px",
    "contentMaxWidth": "48rem",
    "deckMaxWidth": "80rem"
  },

  "animation": {
    "spring": {
      "entrance": { "stiffness": 260, "damping": 24 },
      "confirmation": { "stiffness": 300, "damping": 24 },
      "contentSwap": { "stiffness": 340, "damping": 28 },
      "cardReturn": { "stiffness": 300, "damping": 32 },
      "dotIndicator": { "stiffness": 400, "damping": 28 },
      "notePanel": { "stiffness": 260, "damping": 28 }
    },
    "svgDrawIn": {
      "durationSec": 0.7,
      "easing": "easeOut",
      "staggerSec": 0.16
    },
    "arrowhead": {
      "durationSec": 0.16,
      "delayFormula": "lineDelay + 0.7 * 0.88"
    },
    "nodeAppear": {
      "durationSec": 0.25
    },
    "idleBreathing": {
      "keyframes": { "y": [0, -5, 0] },
      "durationSec": 3,
      "repeat": "Infinity",
      "easing": "easeInOut"
    },
    "swipeHint": {
      "keyframes": { "x": [0, 7, 0] },
      "durationSec": 1.4,
      "repeat": "Infinity",
      "easing": "easeInOut"
    },
    "loadingPulse": {
      "keyframes": { "opacity": [1, 0.65, 1] },
      "durationSec": 1,
      "repeat": "Infinity",
      "easing": "easeInOut"
    },
    "nextButtonPulse": {
      "keyframes": {
        "scale": [1, 1.08, 1],
        "boxShadow": [
          "0 0 0 0 rgba(230,57,70,0.4)",
          "0 0 0 8px rgba(230,57,70,0)",
          "0 0 0 0 rgba(230,57,70,0)"
        ]
      },
      "durationSec": 1.8,
      "repeat": 3,
      "easing": "easeInOut"
    },
    "cardDrag": {
      "elasticity": 0.55,
      "advanceThreshold": { "offsetPx": -70, "velocityPxPerSec": -550 },
      "backThreshold": { "offsetPx": 70, "velocityPxPerSec": 550 },
      "rotateMap": { "input": [-260, 0, 260], "output": [-16, 0, 16] },
      "whileDragScale": 1.03,
      "tapScale": 0.97
    },
    "cardFan": {
      "rotationDeg": [0, 2.6, -2.2, 3],
      "depthScale": 0.045,
      "depthOffsetPx": 8
    },
    "cardExit": {
      "x": "-128%",
      "y": -10,
      "scale": 0.97,
      "rotateDeg": -24,
      "opacity": 0
    },
    "reducedMotion": {
      "cssPolicy": "animation-duration: 0.001ms; animation-iteration-count: 1; transition-duration: 0.001ms",
      "jsPolicy": "All spring transitions set to { duration: 0 }; initial set to false"
    }
  },

  "texture": {
    "paperNoise": {
      "type": "fractalNoise",
      "baseFrequency": 0.85,
      "numOctaves": 2,
      "stitchTiles": "stitch",
      "tileSizePx": 180,
      "blendMode": "multiply",
      "opacity": 0.05
    },
    "inkShadow": {
      "layers": [
        { "offsetX": 0, "offsetY": 0, "blur": 10, "colour": "rgba(245, 240, 232, 0.95)" },
        { "offsetX": 0, "offsetY": 0, "blur": 22, "colour": "rgba(245, 240, 232, 0.85)" },
        { "offsetX": 1, "offsetY": 1, "blur": 0, "colour": "rgba(245, 240, 232, 0.9)" },
        { "offsetX": -1, "offsetY": 0, "blur": 1, "colour": "rgba(245, 240, 232, 0.75)" }
      ]
    }
  },

  "illustration": {
    "viewBox": "0 0 240 150",
    "nodeRadius": 6,
    "nodeStrokeWidth": 2.4,
    "nodeFill": "#efe9dd",
    "ballRadius": 4.4,
    "lineStrokeWidth": 3,
    "lineStrokeWidthRange": [2.6, 3.4],
    "arrowheadSize": 9,
    "arrowheadWingRatio": 0.48,
    "arrowheadStrokeWidth": 2.6,
    "dashPattern": "7 8",
    "zoneDashPattern": "8 8",
    "zoneCornerRadius": 7,
    "strokeLinecap": "round",
    "strokeLinejoin": "round"
  },

  "contact": {
    "support": "team@gogaffa.com",
    "from": "hello@gogaffa.com",
    "fromDisplay": "GoGaffa <hello@gogaffa.com>",
    "copyrightFormat": "GoGaffa © {year}"
  }
}
