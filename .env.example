# GoGaffa environment checklist

## THIS IS JUST A PLACCEHOLDER - WE DON'T HAVE TO FOLLOW THIS EXACTLY
#
# This root file is a reference for everything the repo will need as the app is built out.
# Apps and Supabase functions read their own env files:
#
# - Mobile app: apps/mobile/.env
# - Web app: apps/web/.env.local
# - Supabase Edge Functions: supabase/functions/.env
#
# Never commit real secrets. Keep production values in your deployment provider.

# -----------------------------------------------------------------------------
# Shared app URLs
# -----------------------------------------------------------------------------

# Public web origin used by share links, invite links, redirects, and metadata.
# Local development uses http://localhost:3000.
# Vercel preview currently uses https://gogaffa-nqgt6mnw6-denshimdon-5307s-projects.vercel.app.
# Replace with the final custom/production domain before store submission.
WEB_URL=http://localhost:3000

# Deep-link scheme configured in apps/mobile/app.json.
APP_SCHEME=gogaffa

# development | preview | production
ENVIRONMENT=development

# -----------------------------------------------------------------------------
# Supabase client values
# -----------------------------------------------------------------------------

# Safe to expose in mobile/web clients.
SUPABASE_PROJECT_ID=hnwrhkrzvjesjrtjpjtm
SUPABASE_URL=https://hnwrhkrzvjesjrtjpjtm.supabase.co
SUPABASE_ANON_KEY=

# Server-only. Never expose this in mobile/web client bundles.
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Mobile app public env
# Copy these into apps/mobile/.env
# -----------------------------------------------------------------------------

EXPO_PUBLIC_SUPABASE_URL=https://hnwrhkrzvjesjrtjpjtm.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_WEB_URL=http://localhost:3000
EXPO_PUBLIC_APP_SCHEME=gogaffa
EXPO_PUBLIC_ENVIRONMENT=development
EXPO_PUBLIC_IOS_BUNDLE_IDENTIFIER=com.ivs.gogaffa
EXPO_PUBLIC_ANDROID_PACKAGE=com.ivs.gogaffa
EXPO_PUBLIC_SUPPORT_EMAIL=denshimdon@gmail.com

# -----------------------------------------------------------------------------
# Web app public env
# Copy these into apps/web/.env.local
# -----------------------------------------------------------------------------

NEXT_PUBLIC_SUPABASE_URL=https://hnwrhkrzvjesjrtjpjtm.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_WEB_URL=http://localhost:3000
NEXT_PUBLIC_APP_STORE_URL=
NEXT_PUBLIC_PLAY_STORE_URL=

# -----------------------------------------------------------------------------
# Vercel project metadata
# -----------------------------------------------------------------------------

VERCEL_TEAM_ID=team_lBY9AzfREi5PixiToVkPOZUr
VERCEL_PROJECT_ID=prj_hmrALSf2Kt62HIAOCT1YpsTMZeHi
VERCEL_PROJECT_NAME=gogaffa

# -----------------------------------------------------------------------------
# Supabase Edge Functions
# Copy these into supabase/functions/.env
# -----------------------------------------------------------------------------

SUPABASE_FUNCTIONS_SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_FUNCTIONS_SERVICE_ROLE_KEY=
# Server-only. Never expose Anthropic keys in Expo, Next public env, or client bundles.
ANTHROPIC_API_KEY=
CARD_RENDER_SECRET=
PURCHASE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# AI card generation
# -----------------------------------------------------------------------------

# anthropic | other-provider
# All AI provider calls must be made from Supabase Edge Functions, not the app.
AI_PROVIDER=anthropic
AI_MODEL=
AI_MODERATION_MODEL=

# -----------------------------------------------------------------------------
# Auth providers
# -----------------------------------------------------------------------------

# Supabase Auth providers currently configured in the hosted GoGaffa project:
