# GoGaffa environment checklist

## THIS IS JUST A PLACCEHOLDER - WE DON'T HAVE TO FOLLOW THIS EXACTLY
#
# This root file is a reference for everything the repo will need as the app is built out.
# Apps and Supabase functions read their own env files:
#
# - Mobile app: apps/mobile/.env
# - Supabase Edge Functions: supabase/functions/.env
#
# Never commit real secrets. Keep production values in your deployment provider.

# -----------------------------------------------------------------------------
# Shared app URLs
# -----------------------------------------------------------------------------

# Public waitlist, legal, support, share, and app-download origin.
WEB_URL=https://gogaffa.com
PRIVACY_POLICY_URL=https://gogaffa.com/privacy
TERMS_OF_SERVICE_URL=https://gogaffa.com/terms
SUPPORT_URL=https://gogaffa.com/support

# Deep-link scheme configured in apps/mobile/app.json.
APP_SCHEME=gogaffa
AUTH_CALLBACK_PATH=auth/callback

# development | preview | production
ENVIRONMENT=development

# -----------------------------------------------------------------------------
# Supabase client values
# -----------------------------------------------------------------------------

# Safe to expose in public mobile clients.
SUPABASE_PROJECT_ID=hnwrhkrzvjesjrtjpjtm
SUPABASE_URL=https://hnwrhkrzvjesjrtjpjtm.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_AUTH_SITE_URL=https://gogaffa.com
SUPABASE_AUTH_ADDITIONAL_REDIRECT_URLS=gogaffa://auth/callback,gogaffa://**,exp://**/--/auth/callback,exps://**/--/auth/callback,https://gogaffa.com/**

# Server-only. Never expose this in mobile client bundles.
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Mobile app public env
# Copy these into apps/mobile/.env
# -----------------------------------------------------------------------------

EXPO_PUBLIC_SUPABASE_URL=https://hnwrhkrzvjesjrtjpjtm.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_WEB_URL=https://gogaffa.com
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://gogaffa.com/privacy
EXPO_PUBLIC_TERMS_OF_SERVICE_URL=https://gogaffa.com/terms
EXPO_PUBLIC_SUPPORT_URL=https://gogaffa.com/support
EXPO_PUBLIC_APP_SCHEME=gogaffa
EXPO_PUBLIC_AUTH_CALLBACK_PATH=auth/callback
EXPO_PUBLIC_ENVIRONMENT=development
EXPO_PUBLIC_IOS_BUNDLE_IDENTIFIER=com.ivs.gogaffa
EXPO_PUBLIC_ANDROID_PACKAGE=com.ivs.gogaffa
EXPO_PUBLIC_SUPPORT_EMAIL=denshimdon@gmail.com

# -----------------------------------------------------------------------------
# Supabase Edge Functions
# Copy these into supabase/functions/.env
# -----------------------------------------------------------------------------

SUPABASE_FUNCTIONS_SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_FUNCTIONS_SERVICE_ROLE_KEY=
# OPENAI_API_KEY is consumed only by Supabase Edge Functions.
# Set it locally with: supabase secrets set OPENAI_API_KEY=sk-...
# It must NOT be added to apps/mobile/.env (never ship it to the client).
OPENAI_API_KEY=
CARD_RENDER_SECRET=
PURCHASE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# AI card generation
# -----------------------------------------------------------------------------

# All AI provider calls must be made from Supabase Edge Functions, not the app.
AI_PROVIDER=openai
AI_MODEL=
AI_MODERATION_MODEL=

# -----------------------------------------------------------------------------
# Auth providers
# -----------------------------------------------------------------------------

# Supabase Auth providers currently configured in the hosted GoGaffa project:
# Email, Google, Apple.
# Keep provider client secrets in Supabase Dashboard/config only, not in Expo public env.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=PT8MR25M5P
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Push notifications
# -----------------------------------------------------------------------------

EXPO_ACCESS_TOKEN=
PUSH_NOTIFICATION_PROJECT_ID=b9b7a050-9841-4ed5-9154-eafed8a84bab

# -----------------------------------------------------------------------------
# Mobile purchases
# -----------------------------------------------------------------------------

APPLE_BUNDLE_ID=com.ivs.gogaffa
APPLE_APP_STORE_CONNECT_APP_ID=6775258169
APPLE_SHARED_SECRET=
GOOGLE_PLAY_PACKAGE_NAME=
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=

# Product IDs should match App Store Connect / Play Console.
PRODUCT_ID_CARD_REGENERATION=
PRODUCT_ID_LOCKER_CREDITS_SMALL=
PRODUCT_ID_LOCKER_CREDITS_MEDIUM=
PRODUCT_ID_PREMIUM_COSMETIC=

# -----------------------------------------------------------------------------
# Analytics and monitoring
# -----------------------------------------------------------------------------

ANALYTICS_PROVIDER=
ANALYTICS_API_KEY=
SENTRY_DSN=
