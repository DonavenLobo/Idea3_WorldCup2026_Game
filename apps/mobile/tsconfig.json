{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "declaration": false,
    "jsx": "react-jsx",
    "types": [
      "react"
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@gogaffa/card-renderer": [
        "../../packages/card-renderer/src"
      ],
      "@gogaffa/config": [
        "../../packages/config/src"
      ],
      "@gogaffa/game-engine": [
        "../../packages/game-engine/src"
      ],
      "@gogaffa/types": [
        "../../packages/types/src"
      ],
      "@gogaffa/ui": [
        "../../packages/ui/src"
      ]
    }
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "svg.d.ts"
  ]
}
