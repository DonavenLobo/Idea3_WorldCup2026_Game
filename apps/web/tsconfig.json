{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "allowJs": true,
    "baseUrl": ".",
    "incremental": true,
    "noEmit": true,
    "paths": {
      "@/*": ["src/*"],
      "@world-cup-game/config": ["../../packages/config/src"],
      "@world-cup-game/types": ["../../packages/types/src"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
